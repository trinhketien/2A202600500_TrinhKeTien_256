# ── PRODUCTION ENV — Render + Neon + Upstash ──

# LLM (BẮT BUỘC)
OPENAI_API_KEY=sk-proj-...
DEFAULT_MODEL=gpt-4o

# Database — Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/covankn?sslmode=require

# Redis — Upstash
REDIS_URL=rediss://default:xxx@us1-xxx.upstash.io:6379

# Auth
JWT_SECRET=<run: python -c "import secrets; print(secrets.token_hex(32))">
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend URL (Vercel)
FRONTEND_URL=https://your-app.vercel.app

# Google OAuth (optional — thêm sau)
GOOGLE_CLIENT_ID=

# Stripe (optional — thêm sau)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mem0
MEM0_PROVIDER=local
MEM0_MAX_MEMORIES=200

# Logging
LOG_LEVEL=INFO
