# ── LLM API Keys ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-...

# Default model (dùng GPT-4o cho agent Chiến Lược + Pháp Lý)
DEFAULT_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO

# ── PostgreSQL (chạy trong Docker) ──────────────────────
DATABASE_URL=postgresql://covan_user:covan_local_2026@localhost:5432/covan_db

# ── ChromaDB (chạy trong Docker, port 8100 tránh xung đột FastAPI)
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ── Auth (JWT — mã xác thực người dùng) ────────────────
JWT_SECRET=CHANGE-ME-generate-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Admin mặc định (dùng khi chạy seed_admin.py) ───────
ADMIN_EMAIL=admin@covankn.ai
ADMIN_PASSWORD=CHANGE-ME-strong-password

# ── AI Hook Logging (set by instructor) ─────────────────
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log
